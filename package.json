{
  "name": "agrix-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run start:all",
    "start:all": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd backend && venv/bin/uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "start:frontend": "cd frontend/react_app && npm run dev",
    "install:all": "npm install && npm run install:frontend",
    "install:frontend": "cd frontend/react_app && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
